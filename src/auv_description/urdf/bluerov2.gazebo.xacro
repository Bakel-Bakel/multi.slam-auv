<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Gazebo Harmonic (gz-sim 8) sensors + systems. Only included when
       use_gazebo:=true so the plain URDF stays simulator-agnostic. -->

  <xacro:property name="ns" value="bluerov2"/>

  <!-- ===== Hydrodynamics + added mass on the hull (Fossen-style) ===== -->
  <gazebo>
    <plugin filename="gz-sim-hydrodynamics-system" name="gz::sim::systems::Hydrodynamics">
      <link_name>base_link</link_name>
      <water_density>1025.0</water_density>
      <!-- added mass -->
      <xDotU>-6.0</xDotU>  <yDotV>-7.0</yDotV>  <zDotW>-18.0</zDotW>
      <kDotP>-0.1</kDotP>  <mDotQ>-0.1</mDotQ>  <nDotR>-0.1</nDotR>
      <!-- linear drag -->
      <xU>-4.0</xU>  <yV>-6.0</yV>  <zW>-5.0</zW>
      <kP>-0.5</kP>  <mQ>-0.5</mQ>  <nR>-0.5</nR>
      <!-- quadratic drag -->
      <xUabsU>-18.0</xUabsU> <yVabsV>-21.0</yVabsV> <zWabsW>-36.0</zWabsW>
      <kPabsP>-1.5</kPabsP>  <mQabsQ>-1.5</mQabsQ>  <nRabsR>-1.5</nRabsR>
    </plugin>
  </gazebo>

  <!-- ===== Joint state publisher for propeller joints ===== -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher"/>
  </gazebo>

  <!-- ===== Thruster macro: propeller joint + Thruster system =====
       Each thruster gets a continuous propeller joint and a Thruster system that
       accepts a force command (N) on the gz topic bluerov2/thrusterN (bridged to ROS). -->
  <xacro:macro name="thruster_gz" params="id">
    <link name="thruster${id}_prop">
      <inertial><mass value="0.002"/>
        <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial>
    </link>
    <joint name="thruster${id}_prop_joint" type="continuous">
      <parent link="thruster${id}"/><child link="thruster${id}_prop"/>
      <axis xyz="1 0 0"/><limit effort="-1" velocity="-1"/>
    </joint>
    <gazebo>
      <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
        <namespace>${ns}</namespace>
        <joint_name>thruster${id}_prop_joint</joint_name>
        <thrust_coefficient>0.02</thrust_coefficient>
        <fluid_density>1025.0</fluid_density>
        <propeller_diameter>0.076</propeller_diameter>
        <velocity_control>false</velocity_control>
        <use_angvel_cmd>false</use_angvel_cmd>
        <max_thrust_cmd>50.0</max_thrust_cmd>
        <min_thrust_cmd>-40.0</min_thrust_cmd>
        <topic>thruster${id}</topic>
      </plugin>
    </gazebo>
  </xacro:macro>

  <xacro:thruster_gz id="1"/>
  <xacro:thruster_gz id="2"/>
  <xacro:thruster_gz id="3"/>
  <xacro:thruster_gz id="4"/>
  <xacro:thruster_gz id="5"/>
  <xacro:thruster_gz id="6"/>
  <xacro:if value="${heavy}">
    <xacro:thruster_gz id="7"/>
    <xacro:thruster_gz id="8"/>
  </xacro:if>

  <!-- ===== IMU ===== -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on><update_rate>100</update_rate>
      <topic>imu/data</topic>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- ===== Magnetometer ===== -->
  <gazebo reference="imu_link">
    <sensor name="mag_sensor" type="magnetometer">
      <always_on>1</always_on><update_rate>50</update_rate>
      <topic>magnetic</topic>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- ===== Pressure (depth) ===== -->
  <gazebo reference="pressure_link">
    <sensor name="pressure_sensor" type="air_pressure">
      <always_on>1</always_on><update_rate>20</update_rate>
      <topic>pressure</topic>
      <gz_frame_id>pressure_link</gz_frame_id>
      <air_pressure><reference_altitude>0</reference_altitude></air_pressure>
    </sensor>
  </gazebo>

  <!-- ===== Stereo cameras ===== -->
  <xacro:macro name="camera_gz" params="name side">
    <gazebo reference="${name}_link">
      <sensor name="${name}_cam" type="camera">
        <always_on>1</always_on><update_rate>15</update_rate>
        <topic>cam/${side}/image_raw</topic>
        <camera_info_topic>cam/${side}/camera_info</camera_info_topic>
        <gz_frame_id>${name}_optical_link</gz_frame_id>
        <camera>
          <horizontal_fov>1.5</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.05</near><far>30.0</far></clip>
          <optical_frame_id>${name}_optical_link</optical_frame_id>
        </camera>
      </sensor>
    </gazebo>
  </xacro:macro>
  <xacro:camera_gz name="camera_left" side="left"/>
  <xacro:camera_gz name="camera_right" side="right"/>

  <!-- ===== MBES as a downward GPU lidar (point cloud proxy for bathymetry) =====
       Project DAVE's GPU multibeam replaces this for high fidelity (spec 7.1, 10.4);
       a gpu_lidar gives a working /sonar/mbes/points stream in stock Harmonic. -->
  <gazebo reference="mbes_link">
    <sensor name="mbes" type="gpu_lidar">
      <always_on>1</always_on><update_rate>10</update_rate>
      <topic>sonar/mbes/points</topic>
      <gz_frame_id>mbes_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal><samples>128</samples><resolution>1</resolution>
            <min_angle>-0.5</min_angle><max_angle>0.5</max_angle></horizontal>
          <vertical><samples>64</samples><resolution>1</resolution>
            <min_angle>-0.2</min_angle><max_angle>0.2</max_angle></vertical>
        </scan>
        <range><min>0.2</min><max>40.0</max><resolution>0.01</resolution></range>
      </lidar>
    </sensor>
  </gazebo>

  <!-- ===== Ground-truth odometry (eval only; separate frames) ===== -->
  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <dimensions>3</dimensions>
      <odom_frame>gt_odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_topic>ground_truth/odom</odom_topic>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
  </gazebo>
</robot>
